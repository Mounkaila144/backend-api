APP_NAME="Multi-Tenant API"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_KEY=base64:b20VbpMFQY8wJWcjDi3/8/7LyeT2SOd4XYiaf2enpyQ=

# 🎯 CONNEXION CENTRALE (Base Superadmin avec t_sites)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=site_dev1
DB_USERNAME=root
DB_PASSWORD=
# Cache, Sessions et Queue via Redis local
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# Redis local (même config en dev et prod - installer Redis sur le serveur)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Configuration API
API_PREFIX=api/v1

# Sanctum SPA mode — domains treated as "first-party" (frontends).
# Each tenant frontend host MUST be listed here (or use a wildcard pattern).
# Dev: Next.js can be hit either directly on :3000 or via the tenant host with /api rewrites.
# Prod example: SANCTUM_STATEFUL_DOMAINS=*.icall26.com,admin.icall26.com
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000,tenant1.local,superadmin.local

# Dedicated host for the superadmin interface. Routes /api/superadmin/* are accepted
# ONLY on this host; tenant hosts get 404 to prevent superadmin login leakage.
# In production: SUPERADMIN_DOMAIN=admin.icall26.com
SUPERADMIN_DOMAIN=superadmin.local
SANCTUM_EXPIRATION=60

# Session cookie scope. Leave empty for same-host dev.
# In prod with multi-tenant subdomains: SESSION_DOMAIN=.icall26.com
SESSION_DOMAIN=
SESSION_SAME_SITE=lax
# In prod over HTTPS, set to true to require Secure cookies. Leave empty in dev.
SESSION_SECURE_COOKIE=

# CORS pour Next.js — comma-separated list of "first-party" origins.
# Tenant origins are added dynamically from t_sites (PopulateCorsOrigins middleware).
FRONTEND_URL=http://localhost:3000,http://superadmin.local

# Configuration Tenancy
TENANCY_DATABASE_CONNECTION=mysql
TENANCY_IDENTIFICATION=domain

# PDFtk Server (for pre-meeting PDF generation)
PDFTK_BINARY="C:/Program Files (x86)/PDFtk Server/bin/pdftk.exe"
DOMOPRIME_SITES_DIR="C:/xampp/htdocs/project/sites"

# wkhtmltopdf binary for quotation/billing PDF generation (Symfony parity)
# Use Windows 8.3 short name (PROGRA~1) instead of "Program Files" because
# Snappy / KnpSnappy invokes the binary without quoting paths with spaces.
WKHTMLTOPDF_BINARY="C:/PROGRA~1/wkhtmltopdf/bin/wkhtmltopdf.exe"

# Host that serves the legacy Symfony static assets referenced by the BDD
# Smarty bodies as {$smarty.server.HTTP_HOST}/admin/web/pictures/*.png.
# wkhtmltopdf fetches images from http://{SYMFONY_PDF_HOST}/...
SYMFONY_PDF_HOST=icall.local
