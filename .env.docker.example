################################################################################
# .env DOCKER — copie ce fichier en `.env` et remplace les valeurs marquées
# CHANGE_ME. Ce template diffère de `.env.example` (Laragon) sur quatre points :
#   - REDIS_HOST=redis (nom du service Docker, pas 127.0.0.1)
#   - DB cloud par défaut (pas SQLite)
#   - WKHTMLTOPDF_BINARY=/usr/bin/wkhtmltopdf
#   - SESSION/CACHE/QUEUE pointent sur Redis
#
# IMPORTANT : Docker Compose `env_file` ne supporte PAS les commentaires inline
# (`KEY=value # comment`). Toute la ligne après `=` est prise comme valeur.
# Les commentaires sont donc TOUJOURS sur leur propre ligne, jamais après une
# valeur.
################################################################################

APP_NAME=Laravel

# local en dev, production en prod
APP_ENV=production

# Généré automatiquement par l'installeur (et par entrypoint.sh si vide).
APP_KEY=

# JAMAIS true en prod (leak des stack traces)
APP_DEBUG=false

APP_URL=https://tondomaine.com

# Hôtes Next.js autorisés (CORS + Sanctum stateful). Wildcard supporté.
FRONTEND_URL=https://tondomaine.com
SANCTUM_STATEFUL_DOMAINS=*.tondomaine.com,tondomaine.com

# Hôte dédié au superadmin
SUPERADMIN_DOMAIN=admin.tondomaine.com

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=single
# debug en local, warning/error en prod
LOG_LEVEL=warning

# ----------------------------------------------------------------------------
# Base de données CENTRALE (cloud managé) — CHANGE_ME
# ----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=db-central-xxx.cloud-provider.com
DB_PORT=3306
DB_DATABASE=site_dev1
DB_USERNAME=admin
DB_PASSWORD=__CHANGE_ME__
# Active si ton fournisseur impose TLS (souvent oui en cloud managé)
# MYSQL_ATTR_SSL_CA=/etc/ssl/certs/ca-certificates.crt

# ----------------------------------------------------------------------------
# Redis — service Docker local au VPS (nom du service dans docker-compose.yml)
# ----------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# Sessions / cache / queue → Redis (isolation tenant via préfixe stancl/tenancy)
SESSION_DRIVER=redis
CACHE_STORE=redis
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=log

SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/

# ----------------------------------------------------------------------------
# Storage S3 / MinIO (cloud) — utilisé par TenantStorageManager
# ----------------------------------------------------------------------------
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=__CHANGE_ME__
AWS_SECRET_ACCESS_KEY=__CHANGE_ME__
AWS_DEFAULT_REGION=eu-west-3
AWS_BUCKET=__CHANGE_ME__
AWS_USE_PATH_STYLE_ENDPOINT=false
# AWS_ENDPOINT=https://minio.tondomaine.com   (si MinIO self-hosted)

# ----------------------------------------------------------------------------
# Mail (Resend en prod, log en dev)
# ----------------------------------------------------------------------------
MAIL_MAILER=resend
RESEND_API_KEY=__CHANGE_ME__
MAIL_FROM_ADDRESS="noreply@tondomaine.com"
MAIL_FROM_NAME="${APP_NAME}"

# ----------------------------------------------------------------------------
# PDF binaries (déjà installés dans l'image Docker)
# ----------------------------------------------------------------------------
WKHTMLTOPDF_BINARY=/usr/bin/wkhtmltopdf
SYMFONY_PDF_HOST=

# ----------------------------------------------------------------------------
# Migration — chemin legacy Symfony (rarement utile en Docker, laisser vide)
# ----------------------------------------------------------------------------
LEGACY_PROJECT_PATH=

# ----------------------------------------------------------------------------
# Entrypoint behaviour
#   AUTO_MIGRATE=true : `php artisan migrate --force` à chaque démarrage.
#   FALSE recommandé en cluster (locks de migration). Migre manuellement :
#     docker compose exec app php artisan migrate --force
# ----------------------------------------------------------------------------
AUTO_MIGRATE=false
